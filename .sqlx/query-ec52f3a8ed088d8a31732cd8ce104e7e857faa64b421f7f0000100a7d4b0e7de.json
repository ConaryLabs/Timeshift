  "query": "\n        INSERT INTO org_settings (id, org_id, key, value, updated_at)\n        VALUES ($1, $2, $3, $4, NOW())\n        ON CONFLICT (org_id, key) DO UPDATE\n        SET value = $4, updated_at = NOW()\n        RETURNING id, org_id, key, value, updated_at\n        ",
