  "query": "\n        UPDATE qualifications\n        SET name        = COALESCE($2, name),\n            description = CASE WHEN $3 THEN $4 ELSE description END\n        WHERE id = $1 AND org_id = $5\n        RETURNING id, org_id, name, description, created_at\n        ",
