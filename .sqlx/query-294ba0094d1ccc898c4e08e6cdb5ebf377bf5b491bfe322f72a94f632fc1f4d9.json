{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT ss.id AS scheduled_shift_id,\n               st.name AS shift_template_name,\n               st.start_time,\n               st.end_time,\n               st.duration_minutes\n        FROM scheduled_shifts ss\n        JOIN shift_templates st ON st.id = ss.shift_template_id\n        WHERE ss.org_id = $1\n          AND ss.shift_template_id = $2\n          AND ss.date = $3\n        ",
