  "db_name": "PostgreSQL",
  "query": "\n        SELECT ce.status AS \"status: CalloutStatus\", ce.classification_id,\n               ss.org_id, ss.date AS shift_date, ce.scheduled_shift_id\n        FROM callout_events ce\n        JOIN scheduled_shifts ss ON ss.id = ce.scheduled_shift_id\n        WHERE ce.id = $1\n        ",
