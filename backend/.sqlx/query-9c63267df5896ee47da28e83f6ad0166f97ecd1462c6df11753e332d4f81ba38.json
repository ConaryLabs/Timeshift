  "query": "\n        SELECT ce.status AS \"status: CalloutStatus\", ss.org_id\n        FROM callout_events ce\n        JOIN scheduled_shifts ss ON ss.id = ce.scheduled_shift_id\n        WHERE ce.id = $1\n        FOR UPDATE OF ce\n        ",
