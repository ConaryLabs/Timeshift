  "query": "\n        SELECT bw.id, bw.period_id, bw.seniority_rank, bw.submitted_at, bw.approved_at,\n               sp.org_id\n        FROM bid_windows bw\n        JOIN schedule_periods sp ON sp.id = bw.period_id\n        WHERE bw.id = $1\n        FOR UPDATE\n        ",
