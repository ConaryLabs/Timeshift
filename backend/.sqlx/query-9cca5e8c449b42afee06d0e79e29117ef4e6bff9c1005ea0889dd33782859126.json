{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT a.id, a.user_id, ss.date, ss.org_id, u.classification_id AS \"classification_id?\"\n        FROM assignments a\n        JOIN scheduled_shifts ss ON ss.id = a.scheduled_shift_id\n        JOIN users u ON u.id = a.user_id\n        WHERE a.id = $1\n        ",
