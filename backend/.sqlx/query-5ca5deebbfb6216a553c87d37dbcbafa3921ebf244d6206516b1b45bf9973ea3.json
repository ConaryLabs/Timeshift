{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT v.id, v.callout_event_id, v.user_id,\n               u.first_name, u.last_name,\n               v.volunteered_at\n        FROM ot_volunteers v\n        JOIN users u ON u.id = v.user_id\n        WHERE v.callout_event_id = $1 AND v.org_id = $2\n        ORDER BY v.volunteered_at ASC\n        ",
