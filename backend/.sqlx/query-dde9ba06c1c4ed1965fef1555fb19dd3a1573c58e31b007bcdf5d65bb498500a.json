  "query": "\n        SELECT q.id, q.org_id, q.name, q.description, q.created_at\n        FROM qualifications q\n        JOIN duty_position_qualifications dpq ON dpq.qualification_id = q.id\n        WHERE dpq.duty_position_id = $1\n        ORDER BY q.name\n        ",
